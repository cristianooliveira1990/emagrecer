---
import MainLayout from '../layouts/MainLayout.astro';
import Section from '../components/ui/Section.astro';
import Container from '../components/ui/Container.astro';

const canonicalURL = 'https://emagrecer.xx.kg/contato';
---

<MainLayout
  title="Contato - Emagrecer"
  description="Entre em contato com a equipe do Emagrecer. Dúvidas, sugestões, parcerias ou publicidade - estamos aqui para ajudar."
  canonical={canonicalURL}
>
  <Container maxWidth="prose">
    <Section padding="xl">
      <header class="mb-12 text-center max-w-2xl mx-auto">
        <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface mb-4">
          Entre em Contato
        </h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant">
          Adoraríamos ouvir você. Preencha o formulário ou use nossos canais diretos.
        </p>
      </header>

      <div class="max-w-2xl mx-auto">
        <form action="/api/contact" method="POST" class="space-y-6 bg-surface rounded-xl border border-surface-variant p-8 premium-shadow">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block font-body-md text-body-md font-semibold text-on-surface mb-2">Nome Completo *</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 bg-white border border-outline-variant rounded-lg font-body-md text-body-md text-on-surface focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
                placeholder="Seu nome"
              />
            </div>
            <div>
              <label for="email" class="block font-body-md text-body-md font-semibold text-on-surface mb-2">E-mail *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-white border border-outline-variant rounded-lg font-body-md text-body-md text-on-surface focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
                placeholder="seu@email.com"
              />
            </div>
          </div>
          <div>
            <label for="subject" class="block font-body-md text-body-md font-semibold text-on-surface mb-2">Assunto *</label>
            <select
              id="subject"
              name="subject"
              required
              class="w-full px-4 py-3 bg-white border border-outline-variant rounded-lg font-body-md text-body-md text-on-surface focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
            >
              <option value="">Selecione um assunto</option>
              <option value="general">Dúvida Geral</option>
              <option value="content">Sugestão de Conteúdo</option>
              <option value="partnership">Parceria / Publicidade</option>
              <option value="press">Imprensa</option>
              <option value="technical">Problema Técnico</option>
              <option value="other">Outro</option>
            </select>
          </div>
          <div>
            <label for="message" class="block font-body-md text-body-md font-semibold text-on-surface mb-2">Mensagem *</label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              class="w-full px-4 py-3 bg-white border border-outline-variant rounded-lg font-body-md text-body-md text-on-surface focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all resize-none"
              placeholder="Escreva sua mensagem aqui..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full px-8 py-3 bg-primary hover:bg-primary-container text-on-primary font-label-caps text-label-caps rounded-lg transition-all uppercase tracking-wider"
          >
            Enviar Mensagem
          </button>
        </form>
      </div>
    </Section>

    <!-- Contact Info -->
    <Section padding="xl" background="container-low">
      <Container maxWidth="prose">
        <h2 class="font-headline-md text-headline-md text-on-surface mb-8 text-center">Outras Formas de Contato</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center p-6">
            <div class="w-16 h-16 mx-auto rounded-full bg-secondary-container flex items-center justify-center mb-4">
              <span class="material-symbols-outlined text-primary text-[32px]" data-icon="mail">mail</span>
            </div>
            <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2">E-mail</h3>
            <p class="font-body-md text-body-md text-on-surface-variant mb-1">contato@emagrecer.xx.kg</p>
            <p class="font-body-md text-body-md text-on-surface-variant">Resposta em até 24h úteis</p>
          </div>
          <div class="text-center p-6">
            <div class="w-16 h-16 mx-auto rounded-full bg-secondary-container flex items-center justify-center mb-4">
              <span class="material-symbols-outlined text-primary text-[32px]" data-icon="business">business</span>
            </div>
            <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2">Parcerias e Publicidade</h3>
            <p class="font-body-md text-body-md text-on-surface-variant mb-1">comercial@emagrecer.xx.kg</p>
            <p class="font-body-md text-body-md text-on-surface-variant">Media kit disponível</p>
          </div>
          <div class="text-center p-6">
            <div class="w-16 h-16 mx-auto rounded-full bg-secondary-container flex items-center justify-center mb-4">
              <span class="material-symbols-outlined text-primary text-[32px]" data-icon="schedule">schedule</span>
            </div>
            <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2">Horário de Atendimento</h3>
            <p class="font-body-md text-body-md text-on-surface-variant mb-1">Segunda a Sexta</p>
            <p class="font-body-md text-body-md text-on-surface-variant">9h às 18h (BRT)</p>
          </div>
        </div>
      </Container>
    </Section>

    <!-- FAQ Quick Links -->
    <Section padding="xl">
      <Container maxWidth="prose">
        <h2 class="font-headline-md text-headline-md text-on-surface mb-8 text-center">Perguntas Frequentes</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-2xl mx-auto">
          <a href="/faq" class="p-6 bg-surface rounded-xl border border-surface-variant premium-shadow hover:shadow-lg transition-shadow group">
            <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2 group-hover:text-primary transition-colors">Como assinar a newsletter?</h3>
            <p class="font-body-md text-body-md text-on-surface-variant">Saiba como receber nossos conteúdos semanais.</p>
          </a>
          <a href="/faq" class="p-6 bg-surface rounded-xl border border-surface-variant premium-shadow hover:shadow-lg transition-shadow group">
            <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2 group-hover:text-primary transition-colors">Posso republicar artigos?</h3>
            <p class="font-body-md text-body-md text-on-surface-variant">Entenda nossa política de direitos autorais.</p>
          </a>
          <a href="/faq" class="p-6 bg-surface rounded-xl border border-surface-variant premium-shadow hover:shadow-lg transition-shadow group">
            <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2 group-hover:text-primary transition-colors">Como sugerir um tema?</h3>
            <p class="font-body-md text-body-md text-on-surface-variant">Adoramos sugestões da nossa comunidade.</p>
          </a>
          <a href="/faq" class="p-6 bg-surface rounded-xl border border-surface-variant premium-shadow hover:shadow-lg transition-shadow group">
            <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2 group-hover:text-primary transition-colors">Política de Privacidade</h3>
            <p class="font-body-md text-body-md text-on-surface-variant">Como tratamos seus dados pessoais.</p>
          </a>
        </div>
      </Container>
    </Section>
  </Container>
</MainLayout>