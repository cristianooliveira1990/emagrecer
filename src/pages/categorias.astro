---
import MainLayout from '../layouts/MainLayout.astro';
import Section from '../components/ui/Section.astro';
import Container from '../components/ui/Container.astro';
import { wpClient } from '../services/wp-graphql';

let categories: Array<{ name: string; slug: string; count: number }> = [];
try {
  categories = await wpClient.getCategories(100);
} catch (e) {
  console.warn('Failed to fetch categories:', e);
}
---

<MainLayout
  title="Categorias - Emagrecer"
  description="Explore todos os artigos do Emagrecer organizados por categoria: nutrição, treinos, mente, saúde e mais."
  canonical="https://emagrecer.xx.kg/categorias"
>
  <Container>
    <Section padding="xl">
      <header class="mb-12 text-center max-w-2xl mx-auto">
        <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface mb-4">
          Categorias
        </h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant">
          Navegue pelos artigos por categoria.
        </p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {categories.map((cat) => (
          <a
            href={`/categoria/${cat.slug}`}
            class="group block p-6 bg-surface rounded-xl border border-outline-variant/30 premium-shadow hover:shadow-lg transition-all duration-300"
          >
            <div class="flex items-center justify-between mb-2">
              <h2 class="font-headline-sm text-headline-sm text-on-surface group-hover:text-primary transition-colors">
                {cat.name}
              </h2>
              <span class="material-symbols-outlined text-outline group-hover:text-primary transition-colors" data-icon="chevron_right">chevron_right</span>
            </div>
            <p class="font-body-md text-body-md text-on-surface-variant">
              {cat.count} {cat.count === 1 ? 'artigo' : 'artigos'}
            </p>
          </a>
        ))}
      </div>

      {categories.length === 0 && (
        <p class="text-center font-body-lg text-body-lg text-on-surface-variant py-12">
          Nenhuma categoria encontrada.
        </p>
      )}
    </Section>
  </Container>
</MainLayout>
