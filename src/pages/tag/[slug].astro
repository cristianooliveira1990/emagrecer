---
import MainLayout from '../../layouts/MainLayout.astro';
import ArticleCard from '../../components/article/ArticleCard.astro';
import Section from '../../components/ui/Section.astro';
import Container from '../../components/ui/Container.astro';
import { wpClient } from '../../services/wp-graphql';

export async function getStaticPaths() {
  try {
    const tags = await wpClient.getTags(100);
    return tags.map((tag) => ({
      params: { slug: tag.slug },
      props: { tag },
    }));
  } catch (error) {
    console.warn('Failed to fetch tags from WordPress for static paths:', error);
    return [];
  }
}

interface Props {
  tag: {
    name: string;
    slug: string;
    description: string;
    count: number;
  };
  posts: {
    posts: Array<{
      title: string;
      slug: string;
      excerpt: string;
      date: string;
      featuredImage: { src: string; alt: string; width: number; height: number } | null;
      categories: Array<{ name: string; slug: string }>;
      readingTime: number;
    }>;
    pageInfo: { hasNextPage: boolean; hasPreviousPage: boolean; startCursor: string | null; endCursor: string | null };
  };
  currentPage: number;
  siteUrl: string;
}

const { tag, posts, currentPage, siteUrl } = Astro.props;

const canonicalURL = `${siteUrl}/tag/${tag.slug}${currentPage > 1 ? `/pagina/${currentPage}` : ''}`;
---

<MainLayout
  title={`#${tag.name} - Emagrecer`}
  description={tag.description || `Artigos relacionados à tag ${tag.name}`}
  canonical={canonicalURL}
>
  <Container>
    <!-- Tag Header -->
    <header class="mb-12 text-center max-w-3xl mx-auto">
      <span class="inline-block bg-primary/10 text-primary font-label-caps text-label-caps px-4 py-1 rounded-full mb-4">
        #{tag.name}
      </span>
      <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface mb-4">
        #{tag.name}
      </h1>
      {tag.description && (
        <p class="font-body-lg text-body-lg text-on-surface-variant">
          {tag.description}
        </p>
      )}
      <p class="font-body-md text-body-md text-on-surface-variant mt-4">
        {tag.count} artigo{tag.count !== 1 ? 's' : ''} encontrado{tag.count !== 1 ? 's' : ''}
      </p>
    </header>

    <!-- Posts Grid -->
    {posts.posts.length > 0 ? (
      <Section padding="none">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.posts.map((post) => (
            <ArticleCard post={post} variant="default" />
          ))}
        </div>

        <!-- Pagination -->
        {posts.pageInfo.hasNextPage && (
          <nav class="mt-12 flex justify-center" aria-label="Paginação">
            <a
              href={`/tag/${tag.slug}/pagina/${currentPage + 1}`}
              class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary-container text-on-primary font-label-caps text-label-caps rounded-lg transition-all"
            >
              Próximos artigos
              <span class="material-symbols-outlined" data-icon="chevron_right">chevron_right</span>
            </a>
          </nav>
        )}
      </Section>
    ) : (
      <Section padding="xl">
        <div class="text-center py-16">
          <span class="material-symbols-outlined text-[64px] text-outline-variant mb-4" data-icon="search_off">search_off</span>
          <h2 class="font-headline-sm text-headline-sm text-on-surface mb-2">Nenhum artigo encontrado</h2>
          <p class="font-body-md text-body-md text-on-surface-variant">Não há artigos com esta tag.</p>
        </div>
      </Section>
    )}
  </Container>
</MainLayout>