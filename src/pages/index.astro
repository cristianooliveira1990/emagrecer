---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/layout/Hero.astro';
import ArticleCard from '../components/article/ArticleCard.astro';
import Newsletter from '../components/newsletter/Newsletter.astro';
import Section from '../components/ui/Section.astro';
import Container from '../components/ui/Container.astro';
import { wpClient } from '../services/wp-graphql';

let latestPost: any = null;
let latestPosts: any[] = [];
try {
  const result = await wpClient.getPosts(10);
  const posts = result.nodes.map((p: any) => ({
    ...p,
    categories: p.categories?.nodes || [],
  }));
  latestPost = posts[0] || null;
  latestPosts = posts.slice(1, 10);
} catch (e) {
  console.warn('Failed to fetch posts from WordPress:', e);
}
---

<MainLayout
  title="Emagrecer - Sua Jornada Saudável"
  description="Descubra artigos fundamentados em ciência sobre nutrição, bem-estar mental e treinos que respeitam o seu corpo. Encontre o equilíbrio que você merece."
>
  {latestPost && (
    <Hero
      title={latestPost.title}
      subtitle={latestPost.excerpt?.replace(/<[^>]*>/g, '') || ''}
      ctaText="Ler Artigo"
      ctaHref={`/artigo/${latestPost.slug}`}
      image={{
        src: latestPost.featuredImage?.node?.sourceUrl || '',
        alt: latestPost.featuredImage?.node?.altText || latestPost.title,
        width: latestPost.featuredImage?.node?.mediaDetails?.width || 800,
        height: latestPost.featuredImage?.node?.mediaDetails?.height || 600,
      }}
    />
  )}

  <Section padding="xl">
    <Container>
      <div class="flex justify-between items-end mb-12 border-b border-outline-variant/20 pb-4">
        <h2 class="font-headline-md text-headline-md text-on-background">Últimos Artigos</h2>
        <a href="/artigos" class="font-body-md text-body-md text-primary hover:text-primary-container transition-colors inline-flex items-center space-x-1">
          <span>Ver todos</span>
          <span class="material-symbols-outlined text-[18px]" data-icon="chevron_right">chevron_right</span>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {latestPosts.map((post) => <ArticleCard post={post} variant="default" />)}
      </div>
    </Container>
  </Section>

  <Newsletter />
</MainLayout>
