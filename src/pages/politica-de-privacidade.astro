---
import MainLayout from '../layouts/MainLayout.astro';
import Section from '../components/ui/Section.astro';
import Container from '../components/ui/Container.astro';

const canonicalURL = 'https://emagrecer.xx.kg/politica-de-privacidade';
---

<MainLayout
  title="Política de Privacidade - Emagrecer"
  description="Saiba como coletamos, usamos e protegemos seus dados pessoais em conformidade com a LGPD (Lei nº 13.709/2018)."
  canonical={canonicalURL}
>
  <Container maxWidth="prose">
    <Section padding="xl">
      <header class="mb-12">
        <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface mb-4">
          Política de Privacidade
        </h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant">
          Última atualização: 15 de julho de 2026
        </p>
      </header>

      <article class="prose prose-lg max-w-none space-y-10">
        <section>
          <h2 class="font-headline-md text-headline-md text-on-surface mb-4">1. Introdução</h2>
          <p class="font-body-lg text-body-lg text-on-surface mb-4">
            O <strong>Emagrecer</strong> ("nós", "nosso", "nos") valoriza sua privacidade. Esta Política explica como coletamos, usamos, compartilhamos e protegemos seus dados pessoais quando você acessa nosso site <a href="https://emagrecer.xx.kg" class="text-primary hover:underline">emagrecer.xx.kg</a> ("Site").
          </p>
          <p class="font-body-lg text-body-lg text-on-surface mb-4">
            Estamos comprometidos com a <strong>LGPD (Lei nº 13.709/2018)</strong> e com as melhores práticas de proteção de dados. Ao usar o Site, você concorda com as práticas descritas aqui.
          </p>
        </section>

        <section>
          <h2 class="font-headline-md text-headline-md text-on-surface mb-4">2. Controlador de Dados</h2>
          <p class="font-body-lg text-body-lg text-on-surface mb-4">
            <strong>Emagrecer</strong><br />
            E-mail: <a href="mailto:privacy@emagrecer.xx.kg" class="text-primary hover:underline">privacy@emagrecer.xx.kg</a><br />
            Encarregado de Dados (DPO): Disponível no e-mail acima
          </p>
        </section>

        <section>
          <h2 class="font-headline-md text-headline-md text-on-surface mb-4">3. Dados que Coletamos</h2>

          <h3 class="font-headline-sm text-headline-sm text-on-surface mb-3 mt-6">3.1 Dados Fornecidos Voluntariamente</h3>
          <ul class="list-disc list-inside space-y-2 font-body-lg text-body-lg text-on-surface pl-4">
            <li><strong>Newsletter:</strong> Nome e e-mail (quando você se inscreve)</li>
            <li><strong>Formulário de Contato:</strong> Nome, e-mail, assunto, mensagem</li>
            <li><strong>Comentários:</strong> Nome, e-mail, conteúdo do comentário (se implementado)</li>
          </ul>

          <h3 class="font-headline-sm text-headline-sm text-on-surface mb-3 mt-6">3.2 Dados Coletados Automaticamente</h3>
          <ul class="list-disc list-inside space-y-2 font-body-lg text-body-lg text-on-surface pl-4">
            <li><strong>Dados de Navegação:</strong> IP, tipo de navegador, sistema operacional, páginas visitadas, tempo de permanência, referrer</li>
            <li><strong>Cookies e Tecnologias Similares:</strong> Conforme nossa <a href="/politica-de-cookies" class="text-primary hover:underline">Política de Cookies</a></li>
            <li><strong>Analytics:</strong> Google Analytics (anonimizado), Pagefind (busca local, sem tracking)</li>
          </ul>

          <h3 class="font-headline-sm text-headline-sm text-on-surface mb-3 mt-6">3.3 Dados Sensíveis</h3>
          <p class="font-body-lg text-body-lg text-on-surface mb-4">
            <strong>Não coletamos intencionalmente</strong> dados sensíveis (origem racial, opinião política, convicção religiosa, saúde, vida sexual, genética, biometria) exceto se você nos fornecer voluntariamente em comentários ou contato.
          </p>
        </section>

        <section>
          <h2 class="font-headline-md text-headline-md text-on-surface mb-4">4. Finalidades e Bases Legais</h2>
          <table class="w-full border-collapse mb-6">
            <thead>
              <tr class="bg-surface-container-low border-b border-outline-variant">
                <th class="p-3 text-left font-semibold text-on-surface">Finalidade</th>
                <th class="p-3 text-left font-semibold text-on-surface">Dados</th>
                <th class="p-3 text-left font-semibold text-on-surface">Base Legal (LGPD)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant/30">
              <tr>
                <td class="p-3 text-on-surface-variant">Enviar newsletter</td>
                <td class="p-3 text-on-surface-variant">Nome, e-mail</td>
                <td class="p-3 text-on-surface-variant">Consentimento (Art. 7º, I)</td>
              </tr>
              <tr class="bg-surface-bright">
                <td class="p-3 text-on-surface-variant">Responder contatos</td>
                <td class="p-3 text-on-surface-variant">Nome, e-mail, mensagem</td>
                <td class="p-3 text-on-surface-variant">Legítimo interesse / Consentimento (Art. 7º, I/IX)</td>
              </tr>
              <tr>
                <td class="p-3 text-on-surface-variant">Analytics e melhorias</td>
                <td class="p-3 text-on-surface-variant">Dados de navegação, cookies</td>
                <td class="p-3 text-on-surface-variant">Legítimo interesse (Art. 7º, IX)</td>
              </tr>
              <tr class="bg-surface-bright">
                <td class="p-3 text-on-surface-variant">Segurança e prevenção de fraude</td>
                <td class="p-3 text-on-surface-variant">IP, logs de acesso</td>
                <td class="p-3 text-on-surface-variant">Legítimo interesse / Obrigação legal (Art. 7º, IX/II)</td>
              </tr>
              <tr>
                <td class="p-3 text-on-surface-variant">Cumprir obrigações legais</td>
                <td class="p-3 text-on-surface-variant">Dados cadastrais</td>
                <td class="p-3 text-on-surface-variant">Obrigação legal (Art. 7º, II)</td>
              </tr>
            </tbody>
          </table>
        </section>

        <section>
          <h2 class="font-headline-md text-headline-md text-on-surface mb-4">5. Compartilhamento de Dados</h2>
          <p class="font-body-lg text-body-lg text-on-surface mb-4">
            <strong>Não vendemos seus dados.</strong> Compartilhamos apenas nas situações abaixo:
          </p>
          <ul class="list-disc list-inside space-y-3 font-body-lg text-body-lg text-on-surface pl-4">
            <li><strong>Processadores de Dados:</strong> Provedores de e-mail (ex: ConvertKit, Mailchimp), hospedagem (Vercel), analytics (Google Analytics). Todos com contratos de processamento (DPA) e garantias LGPD.</li>
            <li><strong>Obrigação Legal:</strong> Autoridades competentes mediante ordem judicial ou requisição legal válida.</li>
            <li><strong>Proteção de Direitos:</strong> Para defender nossos direitos, propriedade ou segurança, ou de terceiros.</li>
            <li><strong>Transação Empresarial:</strong> Em caso de fusão, aquisição ou venda de ativos, dados podem ser transferidos (com aviso prévio).</li>
          </ul>
        </section>

        <section>
          <h2 class="font-headline-md text-headline-md text-on-surface mb-4">6. Transferência Internacional</h2>
          <p class="font-body-lg text-body-lg text-on-surface mb-4">
            Alguns processadores podem estar fora do Brasil (EUA, Europa). Garantimos proteção adequada via:
          </p>
          <ul class="list-disc list-inside space-y-2 font-body-lg text-body-lg text-on-surface pl-4">
            <li>Cláusulas contratuais padrão (SCCs) aprovadas pela ANPD</li>
            <li>Certificações (ex: Privacy Framework, ISO 27001)</li>
            <li>Regras corporativas globais (BCRs) quando aplicável</li>
          </ul>
        </section>

        <section>
          <h2 class="font-headline-md text-headline-md text-on-surface mb-4">7. Retenção de Dados</h2>
          <table class="w-full border-collapse mb-6">
            <thead>
              <tr class="bg-surface-container-low border-b border-outline-variant">
                <th class="p-3 text-left font-semibold text-on-surface">Categoria</th>
                <th class="p-3 text-left font-semibold text-on-surface">Período</th>
                <th class="p-3 text-left font-semibold text-on-surface">Critério</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant/30">
              <tr>
                <td class="p-3 text-on-surface-variant">Newsletter (ativos)</td>
                <td class="p-3 text-on-surface-variant">Enquanto consentimento válido</td>
                <td class="p-3 text-on-surface-variant">Até descadastro</td>
              </tr>
              <tr class="bg-surface-bright">
                <td class="p-3 text-on-surface-variant">Newsletter (inativos)</td>
                <td class="p-3 text-on-surface-variant">12 meses sem engajamento</td>
                <td class="p-3 text-on-surface-variant">Limpeza automática + LGPD</td>
              </tr>
              <tr>
                <td class="p-3 text-on-surface-variant">Formulário de contato</td>
                <td class="p-3 text-on-surface-variant">6 meses após resposta</td>
                <td class="p-3 text-on-surface-variant">Finalidade cumprida</td>
              </tr>
              <tr class="bg-surface-bright">
                <td class="p-3 text-on-surface-variant">Logs de acesso / Analytics</td>
                <td class="p-3 text-on-surface-variant">12 meses</td>
                <td class="p-3 text-on-surface-variant">Segurança / Legítimo interesse</td>
              </tr>
              <tr>
                <td class="p-3 text-on-surface-variant">Cookies</td>
                <td class="p-3 text-on-surface-variant">Conforme Política de Cookies</td>
                <td class="p-3 text-on-surface-variant">Consentimento / Legítimo interesse</td>
              </tr>
            </tbody>
          </table>
          <p class="font-body-lg text-body-lg text-on-surface">
            Após o período, dados são <strong>anonimizados irreversivelmente</strong> ou <strong>excluídos com segurança</strong>.
          </p>
        </section>

        <section>
          <h2 class="font-headline-md text-headline-md text-on-surface mb-4">8. Seus Direitos (LGPD - Art. 18)</h2>
          <p class="font-body-lg text-body-lg text-on-surface mb-4">
            Você tem direito a solicitar, a qualquer momento:
          </p>
          <ul class="list-disc list-inside space-y-3 font-body-lg text-body-lg text-on-surface pl-4">
            <li><strong>Confirmação e Acesso:</strong> Saber se tratamos seus dados e quais</li>
            <li><strong>Correção:</strong> Dados incompletos, inexatos ou desatualizados</li>
            <li><strong>Anonimização, Bloqueio ou Eliminação:</strong> Dados desnecessários, excessivos ou em desacordo com a LGPD</li>
            <li><strong>Portabilidade:</strong> Receber seus dados em formato estruturado</li>
            <li><strong>Eliminação:</strong> Dados tratados com consentimento (exceto exceções legais)</li>
            <li><strong>Informação sobre Compartilhamento:</strong> Com quem compartilhamos</li>
            <li><strong>Revogação do Consentimento:</strong> A qualquer momento, sem afetar legalidade anterior</li>
            <li><strong>Oposição:</strong> Tratamento baseado em legítimo interesse</li>
            <li><strong>Revisão de Decisões Automatizadas:</strong> Se houver (não temos atualmente)</li>
          </ul>
          <div class="bg-primary/5 border-l-4 border-primary p-6 rounded-r-lg mt-6">
            <h3 class="font-headline-sm text-headline-sm text-primary mb-3">Como exercer seus direitos</h3>
            <p class="font-body-lg text-body-lg text-on-surface mb-2">
              Envie e-mail para <a href="mailto:privacy@emagrecer.xx.kg" class="font-semibold text-primary hover:underline">privacy@emagrecer.xx.kg</a> com assunto "LGPD - Direitos do Titular".
            </p>
            <p class="font-body-lg text-body-lg text-on-surface">
              Responderemos em até <strong>15 dias</strong> (conforme Art. 18, §1º da LGPD). Podemos solicitar comprovação de identidade.
            </p>
          </div>
        </section>

        <section>
          <h2 class="font-headline-md text-headline-md text-on-surface mb-4">9. Segurança dos Dados</h2>
          <p class="font-body-lg text-body-lg text-on-surface mb-4">
            Implementamos medidas técnicas e organizacionais adequadas:
          </p>
          <ul class="list-disc list-inside space-y-2 font-body-lg text-body-lg text-on-surface pl-4">
            <li>HTTPS/TLS 1.3 em todo o site (HSTS, CSP, headers de segurança)</li>
            <li>Hospedagem na Vercel (SOC 2 Type II, ISO 27001)</li>
            <li>Headers de segurança: X-Frame-Options, X-Content-Type-Options, Referrer-Policy, Permissions-Policy</li>
            <li>Acesso restrito a dados (princípio do menor privilégio)</li>
            <li>Monitoramento de segurança e resposta a incidentes</li>
            <li>Backups criptografados e testados</li>
          </ul>
          <p class="font-body-lg text-body-lg text-on-surface mt-4">
            <strong>Nenhum sistema é 100% seguro.</strong> Em caso de incidente de segurança com risco para seus direitos, notificaremos você e a ANPD conforme Art. 48 da LGPD.
          </p>
        </section>

        <section>
          <h2 class="font-headline-md text-headline-md text-on-surface mb-4">10. Cookies e Tecnologias Similares</h2>
          <p class="font-body-lg text-body-lg text-on-surface mb-4">
            Consulte nossa <a href="/politica-de-cookies" class="text-primary hover:underline font-semibold">Política de Cookies completa</a>. Resumo:
          </p>
          <ul class="list-disc list-inside space-y-2 font-body-lg text-body-lg text-on-surface pl-4">
            <li><strong>Essenciais:</strong> Sessão, segurança, preferências de consentimento (não desativáveis)</li>
            <li><strong>Analytics:</strong> Google Analytics (IP anonimizado), apenas com consentimento</li>
            <li><strong>Busca:</strong> Pagefind (local, sem cookies, sem tracking)</li>
            <li><strong>Terceiros:</strong> YouTube (no-c cookie), fontes Google (preconnect)</li>
          </ul>
          <p class="font-body-lg text-body-lg text-on-surface mt-4">
            Gerencie preferências no <a href="/politica-de-cookies#gerenciar" class="text-primary hover:underline">banner de cookies</a> ou nas configurações do navegador.
          </p>
        </section>

        <section>
          <h2 class="font-headline-md text-headline-md text-on-surface mb-4">11. Crianças e Adolescentes</h2>
          <p class="font-body-lg text-body-lg text-on-surface mb-4">
            O Site não se destina a menores de 18 anos. Não coletamos intencionalmente dados de menores. Se você é pai/mãe/tutor e acredita que seu filho nos forneceu dados, entre em contato para exclusão imediata.
          </p>
        </section>

        <section>
          <h2 class="font-headline-md text-headline-md text-on-surface mb-4">12. Alterações desta Política</h2>
          <p class="font-body-lg text-body-lg text-on-surface mb-4">
            Podemos atualizar esta Política periodicamente. A versão vigente sempre terá a data de "Última atualização" no topo. Alterações materiais serão comunicadas via:
          </p>
          <ul class="list-disc list-inside space-y-2 font-body-lg text-body-lg text-on-surface pl-4">
            <li>Banner no site</li>
            <li>E-mail (se você tiver newsletter ativa)</li>
            <li>Publicação da nova versão nesta página</li>
          </ul>
        </section>

        <section>
          <h2 class="font-headline-md text-headline-md text-on-surface mb-4">13. Contato</h2>
          <p class="font-body-lg text-body-lg text-on-surface mb-2">
            Dúvidas, solicitações ou reclamações sobre privacidade:
          </p>
          <ul class="list-none space-y-2 font-body-lg text-body-lg text-on-surface pl-4">
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary" data-icon="mail">mail</span> <a href="mailto:privacy@emagrecer.xx.kg" class="text-primary hover:underline">privacy@emagrecer.xx.kg</a></li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary" data-icon="contact_support">contact_support</span> <a href="/contato" class="text-primary hover:underline">Formulário de Contato</a> (assunto: Privacidade)</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary" data-icon="gavel">gavel</span> ANPD: <a href="https://www.gov.br/anpd" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">www.gov.br/anpd</a></li>
          </ul>
        </section>
      </article>
    </Section>

    <!-- Related Links -->
    <Section padding="xl" background="container-low">
      <Container maxWidth="prose">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <a href="/termos-de-uso" class="p-6 bg-surface rounded-xl border border-surface-variant premium-shadow hover:shadow-lg transition-shadow">
            <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2">Termos de Uso</h3>
            <p class="font-body-md text-body-md text-on-surface-variant">Regras de uso do site e conteúdo</p>
          </a>
          <a href="/politica-de-cookies" class="p-6 bg-surface rounded-xl border border-surface-variant premium-shadow hover:shadow-lg transition-shadow">
            <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2">Política de Cookies</h3>
            <p class="font-body-md text-body-md text-on-surface-variant">Detalhes sobre cookies e tecnologias</p>
          </a>
        </div>
      </Container>
    </Section>
  </Container>
</MainLayout>