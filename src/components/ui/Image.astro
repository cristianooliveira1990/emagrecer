---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
  priority?: boolean;
  sizes?: string;
  quality?: number;
  format?: 'avif' | 'webp' | 'jpg' | 'png';
}

const {
  src,
  alt,
  width,
  height,
  class: className = '',
  loading = 'lazy',
  priority = false,
  sizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw',
  quality = 80,
  format = 'avif',
} = Astro.props;

const externalUrl = typeof src === 'string' && (src.startsWith('http') || src.startsWith('//'));
---

{externalUrl ? (
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    class:list={['block', className]}
    loading={loading}
    fetchpriority={priority ? 'high' : 'auto'}
    decoding="async"
  />
) : (
  <picture>
    <source type="image/avif" srcSet={getImage({ src, format: 'avif', quality, widths: [400, 800, 1200, 1600] }).srcSet} sizes={sizes} />
    <source type="image/webp" srcSet={getImage({ src, format: 'webp', quality, widths: [400, 800, 1200, 1600] }).srcSet} sizes={sizes} />
    <img
      src={getImage({ src, format: 'jpg', quality, width: width || 800 }).src}
      alt={alt}
      width={width}
      height={height}
      class:list={['block', className]}
      loading={loading}
      fetchpriority={priority ? 'high' : 'auto'}
      decoding="async"
    />
  </picture>
)}