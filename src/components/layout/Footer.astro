---
import Container from '../ui/Container.astro';

interface FooterLink {
  label: string;
  href: string;
}

interface Props {
  siteName?: string;
  description?: string;
  copyright?: string;
  navigation?: {
    community?: FooterLink[];
    legal?: FooterLink[];
    contact?: FooterLink[];
  };
  socialMedia?: {
    instagram?: string;
    twitter?: string;
    youtube?: string;
  };
}

const {
  siteName = 'Emagrecer',
  description = 'Seu hub diário para nutrição baseada em evidências, saúde mental e movimento consciente.',
  copyright = `© ${new Date().getFullYear()} Emagrecer. Dedicados ao seu bem-estar e equilíbrio diário.`,
  navigation = {
    community: [
      { label: 'Sobre Nós', href: '/sobre' },
      { label: 'Contato', href: '/contato' },
      { label: 'Anuncie', href: '/anuncie' },
    ],
    legal: [
      { label: 'Política de Privacidade', href: '/politica-de-privacidade' },
      { label: 'Termos de Uso', href: '/termos-de-uso' },
    ],
    contact: [
      { label: 'Contato', href: '/contato' },
      { label: 'Anuncie', href: '/anuncie' },
    ],
  },
  socialMedia = {
    instagram: '#',
    twitter: '#',
    youtube: '#',
  },
} = Astro.props;
---

<footer class="w-full py-section-gap border-t border-outline-variant/20 bg-surface-container-low dark:bg-surface-container-lowest flat no-shadows">
  <Container class="grid grid-cols-1 md:grid-cols-4 gap-gutter">
    <!-- Brand & Description -->
    <div class="md:col-span-1 space-y-4">
      <a href="/" class="font-display-lg-mobile text-display-lg-mobile text-primary dark:text-primary-fixed tracking-tighter inline-block mb-2">
        {siteName}
      </a>
      <p class="font-body-md text-body-md text-on-surface-variant max-w-[250px]">
        {description}
      </p>
      <div class="flex space-x-4">
        {socialMedia.instagram && (
          <a
            href={socialMedia.instagram}
            aria-label="Instagram"
            class="text-on-surface-variant hover:text-primary transition-colors"
          >
            <span class="material-symbols-outlined" data-icon="photo_camera">photo_camera</span>
          </a>
        )}
        {socialMedia.twitter && (
          <a
            href={socialMedia.twitter}
            aria-label="Twitter"
            class="text-on-surface-variant hover:text-primary transition-colors"
          >
            <span class="material-symbols-outlined" data-icon="chat">chat</span>
          </a>
        )}
        {socialMedia.youtube && (
          <a
            href={socialMedia.youtube}
            aria-label="YouTube"
            class="text-on-surface-variant hover:text-primary transition-colors"
          >
            <span class="material-symbols-outlined" data-icon="smart_display">smart_display</span>
          </a>
        )}
      </div>
    </div>

    <!-- Community Links -->
    <div class="md:col-span-1 md:col-start-3">
      <h4 class="font-headline-sm text-headline-sm text-on-background mb-4 text-[18px]">Comunidade</h4>
      <ul class="space-y-3">
        {navigation.community?.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-body-md text-body-md text-on-surface-variant dark:text-on-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors focus:ring-2 focus:ring-primary rounded"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Legal Links -->
    <div class="md:col-span-1">
      <h4 class="font-headline-sm text-headline-sm text-on-background mb-4 text-[18px]">Legal</h4>
      <ul class="space-y-3">
        {navigation.legal?.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-body-md text-body-md text-on-surface-variant dark:text-on-surface-variant hover:text-primary dark:hover:text-primary-fixed transition-colors focus:ring-2 focus:ring-primary rounded"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Copyright -->
    <div class="md:col-span-1 flex flex-col justify-end">
      <p class="font-body-md text-body-md text-secondary dark:text-secondary-fixed-dim">
        {copyright}
      </p>
    </div>
  </Container>
</footer>